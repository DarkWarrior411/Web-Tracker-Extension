{
  "manifest_version": 3,
  "name": "Web Tracker Pro",
  "version": "1.0",
  "description": "Track leads, save URLs, and remember exact scroll positions.",
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}